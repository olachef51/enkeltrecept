    const preferredDisplayUnits = {
      volume: ["l", "dl", "ml", "msk", "tsk", "krm"],
      weight: ["kg", "hg", "g"],
      piece: ["st", "pkt", "burk", "burkar", "skiva", "skivor", "klyfta", "klyftor"]
    };

    let bankItemCounter = 1;
    let savedStepCounter = 1;
    let builderIngredientCounter = 1;

    const state = {
      title: "",
      ingredientBank: [],
      instructionBank: [...defaultInstructionLibrary.map(item => ({ ...item }))],
      builder: {
        ingredients: [],
        instructions: [],
        customInstruction: "",
        restMinutes: 0,
        ovenTemp: "",
        ovenMinutes: "",
        targetTemp: ""
      },
      recipeSteps: []
    };

    const ingredientBankEl = document.getElementById("ingredientBank");
    const instructionBankEl = document.getElementById("instructionBank");
    const builderIngredientZoneEl = document.getElementById("builderIngredientZone");
    const builderInstructionZoneEl = document.getElementById("builderInstructionZone");
    const builderCustomInstructionEl = document.getElementById("builderCustomInstruction");
    const builderSpecialHostEl = document.getElementById("builderSpecialHost");
    const builderPreviewHostEl = document.getElementById("builderPreviewHost");
    const savedStepsEl = document.getElementById("savedSteps");
    const recipePreviewEl = document.getElementById("recipePreview");
    const recipeTitleInput = document.getElementById("recipeTitleInput");
    const recipeTitlePreview = document.getElementById("recipeTitlePreview");
    const importText = document.getElementById("importText");
    const parseRecipeBtn = document.getElementById("parseRecipeBtn");
    const importIngredientsBtn = document.getElementById("importIngredientsBtn");
    const clearImportBtn = document.getElementById("clearImportBtn");
    const clearBankBtn = document.getElementById("clearBankBtn");
    const saveStepBtn = document.getElementById("saveStepBtn");
    const clearBuilderBtn = document.getElementById("clearBuilderBtn");
    const printBtn = document.getElementById("printBtn");
    const printBtnBottom = document.getElementById("printBtnBottom");
    const saveRecipeBtn = document.getElementById("saveRecipeBtn");
    const saveRecipeBtnBottom = document.getElementById("saveRecipeBtnBottom");
    const resetRecipeBtn = document.getElementById("resetRecipeBtn");
    const resetRecipeBtnBottom = document.getElementById("resetRecipeBtnBottom");
    const recipeUrlInput = document.getElementById("recipeUrlInput");
    const importUrlBtn = document.getElementById("importUrlBtn");
    const urlImportStatus = document.getElementById("urlImportStatus");

    function normalizeLine(line){
      return String(line || "").replace(/\u00A0/g, " ").replace(/\s+/g, " ").trim();
    }

    function cleanLines(text){
      return String(text || "").split(/\r?\n/).map(normalizeLine).filter(Boolean);
    }

    function setUrlStatus(message, type){
      urlImportStatus.textContent = message;
      urlImportStatus.className = "status-box" + (type ? " " + type : "");
    }

    function dedupeLines(lines){
      const seen = new Set();
      const result = [];
      lines.forEach(line => {
        const clean = normalizeLine(line);
        const key = clean.toLowerCase();
        if (!clean || seen.has(key)) return;
        seen.add(key);
        result.push(clean);
      });
      return result;
    }

    function dedupeAgainstBank(lines){
      const existing = new Set(state.ingredientBank.map(item => normalizeLine(item.label).toLowerCase()));
      return lines.filter(line => !existing.has(normalizeLine(line).toLowerCase()));
    }

    function shouldBlockIngredientLine(line){
      const lower = normalizeLine(line).toLowerCase();
      if (!lower) return true;
      if (/^\[.*?\]\(.*?\)$/.test(lower)) return true;
      if (blockedIngredientPhrases.some(phrase => lower.includes(phrase))) return true;
      return false;
    }

    function extractMarkdownSectionLines(rawText, headingText){
      const lines = String(rawText || "").split(/\r?\n/);
      const target = headingText.toLowerCase();
      let startIndex = -1;

      for (let i = 0; i < lines.length; i++) {
        const line = normalizeLine(lines[i]).toLowerCase();
        if (line === target) {
          startIndex = i + 1;
          break;
        }
      }

      if (startIndex === -1) return [];

      const sectionLines = [];
      for (let i = startIndex; i < lines.length; i++) {
        const line = normalizeLine(lines[i]);
        if (!line) continue;
        if (/^##\s+/.test(line)) break;
        sectionLines.push(line);
      }

      return sectionLines;
    }

    function cleanupIngredientLine(line){
      return normalizeLine(
        String(line || "")
          .replace(/^[-*•]\s*/, "")
          .replace(/^\d+\.\s*/, "")
      );
    }

    function extractIngredientsFromMarkdownHeadings(rawText){
      const ingredientLines = extractMarkdownSectionLines(rawText, "## Ingredienser")
        .map(cleanupIngredientLine)
        .filter(Boolean)
        .filter(line => !shouldBlockIngredientLine(line))
        .filter(line => isLikelyIngredient(line));

      if (!ingredientLines.length) return null;

      return {
        title: "",
        ingredients: dedupeLines(ingredientLines),
        instructions: []
      };
    }

    function isLikelyHeading(line){
      const lower = line.toLowerCase();
      return [
        "ingredienser",
        "du behöver",
        "gör så här",
        "gör såhär",
        "instruktioner",
        "tillagning",
        "så här gör du",
        "sa har gor du",
        "metod",
        "för alla",
        "klimatanpassa"
      ].includes(lower);
    }

    function isIngredientHeading(line){
      const lower = line.toLowerCase();
      return ["ingredienser", "du behöver"].includes(lower);
    }

    function isLikelyIngredient(line){
      const lower = line.toLowerCase();

      if (/^\d+\s*$/.test(lower)) return false;
      if (isLikelyHeading(lower)) return false;
      if (/^\d+\./.test(lower)) return false;
      if (/^steg\s*\d+/i.test(lower)) return false;
      if (shouldBlockIngredientLine(lower)) return false;

      const measurementPattern = /\b(dl|ml|l|g|kg|hg|msk|tsk|krm|st|pkt|burk|burkar|nypa|nypor|droppe|droppar|cm|skiva|skivor|klyfta|klyftor)\b/i;
      const amountPattern = /^(\d+([.,]\d+)?|[½¼¾]|en|ett|två|tre|fyra|fem|sex|sju|åtta|nio|tio)\b/i;

      if (measurementPattern.test(lower)) return true;
      if (amountPattern.test(lower) && lower.split(" ").length <= 8) return true;
      if (/^\d+[.,]?\d*\s*[a-zåäö]/i.test(lower) && lower.split(" ").length <= 8) return true;

      return false;
    }

    function extractUsefulTextFromFetchedPage(raw){
      let text = String(raw || "");
      text = text.replace(/```[\s\S]*?```/g, " ");
      text = text.replace(/\[([^\]]+)\]\((.*?)\)/g, "$1");
      text = text.replace(/[ \t]+\n/g, "\n");
      text = text.replace(/\n{3,}/g, "\n\n");
      return text.trim();
    }

    function strictExtractIngredientSections(rawText){
      const lines = cleanLines(rawText);
      if (!lines.length) return null;

      let title = "";
      let ingredients = [];

      const firstNonHeading = lines.find(line => !isLikelyHeading(line) && !isLikelyIngredient(line));
      if (firstNonHeading && firstNonHeading.length <= 120) {
        title = firstNonHeading;
      }

      let mode = "";
      let ingredientFound = false;

      for (let i = 0; i < lines.length; i++) {
        const line = normalizeLine(lines[i]);
        if (title && line === title) continue;

        if (isIngredientHeading(line)) {
          mode = "ingredients";
          ingredientFound = true;
          continue;
        }

        if (!mode) continue;
        if (mode === "ingredients" && isLikelyIngredient(line) && !shouldBlockIngredientLine(line)) {
          ingredients.push(line);
        }
      }

      ingredients = dedupeLines(ingredients.filter(Boolean));

      if (!ingredientFound || !ingredients.length) return null;

      return { title, ingredients, instructions: [] };
    }

    function parseSwedishAmountToNumber(amountText){
      let text = normalizeLine(amountText)
        .replace(/,/g, ".")
        .replace(/½/g, " 1/2")
        .replace(/¼/g, " 1/4")
        .replace(/¾/g, " 3/4")
        .replace(/\ben\b/gi, "1")
        .replace(/\bett\b/gi, "1")
        .replace(/\btvå\b/gi, "2")
        .replace(/\btre\b/gi, "3")
        .replace(/\bfyra\b/gi, "4")
        .replace(/\bfem\b/gi, "5")
        .replace(/\bsex\b/gi, "6")
        .replace(/\bsju\b/gi, "7")
        .replace(/\båtta\b/gi, "8")
        .replace(/\bnio\b/gi, "9")
        .replace(/\btio\b/gi, "10");

      const parts = text.split(" ").filter(Boolean);
      let total = 0;
      let found = false;

      parts.forEach(part => {
        if (/^\d+\/\d+$/.test(part)) {
          const [a, b] = part.split("/").map(Number);
          if (b) {
            total += a / b;
            found = true;
          }
        } else if (/^\d+(\.\d+)?$/.test(part)) {
          total += Number(part);
          found = true;
        }
      });

      return found ? total : null;
    }

    function formatSwedishNumber(value){
      const rounded = Math.round(value * 100) / 100;
      if (Math.abs(rounded - Math.round(rounded)) < 0.0001) return String(Math.round(rounded));
      return String(rounded).replace(".", ",");
    }

    function getUnitSystem(unit){
      const lowerUnit = normalizeLine(unit).toLowerCase();
      if (lowerUnit in unitSystems.volume) return "volume";
      if (lowerUnit in unitSystems.weight) return "weight";
      if (lowerUnit in unitSystems.piece) return "piece";
      return null;
    }

    function convertToBaseUnit(amount, unit, system){
      if (!system || amount === null || amount === undefined) return null;
      const factor = unitSystems[system]?.[unit];
      if (!factor) return null;
      return amount * factor;
    }

    function convertFromBaseUnit(baseAmount, unit, system){
      if (!system || baseAmount === null || baseAmount === undefined) return null;
      const factor = unitSystems[system]?.[unit];
      if (!factor) return null;
      return baseAmount / factor;
    }

    function formatAmountWithUnit(amount, unit){
      return `${formatSwedishNumber(amount)} ${unit}`;
    }

    function formatIngredientFromBase(baseAmount, system, restText, preferredUnit){
      if (!system || baseAmount === null || baseAmount === undefined) {
        return restText || "";
      }

      const units = preferredUnit ? [preferredUnit, ...preferredDisplayUnits[system].filter(u => u !== preferredUnit)] : preferredDisplayUnits[system];
      let chosenUnit = preferredUnit || units[0];
      let chosenAmount = convertFromBaseUnit(baseAmount, chosenUnit, system);

      for (const unit of units) {
        const amount = convertFromBaseUnit(baseAmount, unit, system);
        if (amount === null) continue;
        const roundedAmount = Math.round(amount * 100) / 100;
        if (roundedAmount >= 1 && roundedAmount <= 20) {
          chosenUnit = unit;
          chosenAmount = amount;
          break;
        }
      }

      const amountText = formatAmountWithUnit(chosenAmount, chosenUnit);
      return `${amountText}${restText ? " " + restText : ""}`.trim();
    }

    function parseIngredientParts(text){
      const clean = normalizeLine(text);
      const measureMatch = clean.match(/^(.+?)\s+(dl|ml|l|g|kg|hg|msk|tsk|krm|st|pkt|burk|burkar|skiva|skivor|klyfta|klyftor)\b(.*)$/i);

      if (measureMatch) {
        const amountRaw = normalizeLine(measureMatch[1]);
        const unit = normalizeLine(measureMatch[2]).toLowerCase();
        const rest = normalizeLine(measureMatch[3]);
        const numericValue = parseSwedishAmountToNumber(amountRaw);
        const system = getUnitSystem(unit);
        const baseAmount = numericValue !== null ? convertToBaseUnit(numericValue, unit, system) : null;

        if (numericValue !== null && system && baseAmount !== null) {
          return {
            original: clean,
            hasAdjustableQty: true,
            amountRaw,
            unit,
            rest,
            numericValue,
            system,
            baseAmount
          };
        }
      }

      const pieceMatch = clean.match(/^((?:\d+(?:[.,]\d+)?|[½¼¾]|\d+\s+\d+\/\d+|\d+\/\d+|en|ett|två|tre|fyra|fem|sex|sju|åtta|nio|tio))\s+(.+)$/i);
      if (pieceMatch) {
        const amountRaw = normalizeLine(pieceMatch[1]);
        const rest = normalizeLine(pieceMatch[2]);
        const numericValue = parseSwedishAmountToNumber(amountRaw);
        const unit = "st";
        const system = "piece";
        const baseAmount = numericValue !== null ? convertToBaseUnit(numericValue, unit, system) : null;

        if (numericValue !== null && baseAmount !== null && rest) {
          return {
            original: clean,
            hasAdjustableQty: true,
            amountRaw,
            unit,
            rest,
            numericValue,
            system,
            baseAmount
          };
        }
      }

      return {
        original: clean,
        hasAdjustableQty: false,
        amountRaw: "",
        unit: "",
        rest: clean,
        numericValue: null,
        system: null,
        baseAmount: null
      };
    }

    function getDefaultIngredientHelp(text, parts){
      const lower = normalizeLine(text).toLowerCase();
      if (lower === "margarin / olja för stekning") return "alltid tillgänglig";
      return parts.hasAdjustableQty ? "kan delas upp" : "importerad ingrediens";
    }

    function getDefaultIngredientSource(text, extra){
      if (extra && extra.source) return extra.source;
      if (normalizeLine(text).toLowerCase() === "margarin / olja för stekning") return "fixed";
      return "imported";
    }

    function getAlwaysAvailableIngredientItems(){
      return alwaysAvailableIngredients.map(text => createIngredientItem(text, { source: "fixed" }));
    }

    function resetIngredientBankWithAlwaysAvailable(){
      state.ingredientBank = getAlwaysAvailableIngredientItems();
    }

    function getIngredientDisplayLabel(item){
      return item.adjustedLabel || item.label;
    }

    function getIconMarkup(icon){
      if (customSvgIcons[icon]) return customSvgIcons[icon];
      return escapeHtml(icon);
    }

    function createIngredientItem(text, extra = {}){
      const parts = parseIngredientParts(text);
      return {
        id: extra.id || "bank-ingredient-" + bankItemCounter++,
        type: "ingredient",
        icon: "🥄",
        label: text,
        help: extra.help || getDefaultIngredientHelp(text, parts),
        source: getDefaultIngredientSource(text, extra),
        hasAdjustableQty: parts.hasAdjustableQty,
        unit: parts.unit || "",
        rest: parts.rest || "",
        numericValue: parts.numericValue,
        system: parts.system,
        baseAmount: parts.baseAmount,
        adjustedLabel: extra.adjustedLabel || text,
        selectedSplitUnit: extra.selectedSplitUnit || (parts.unit || ""),
        selectedSplitAmount: extra.selectedSplitAmount || "all",
        leftoverId: extra.leftoverId || null,
        originalBankId: extra.originalBankId || null,
        builderId: extra.builderId || null
      };
    }

    function makeBuilderIngredientFromBankItem(item){
      return {
        ...item,
        builderId: "builder-ingredient-" + builderIngredientCounter++,
        originalBankId: item.id,
        adjustedLabel: item.label,
        selectedSplitUnit: item.unit || "",
        selectedSplitAmount: "all",
        leftoverId: null
      };
    }

    function getSplitUnitOptions(item){
      if (!item.hasAdjustableQty || !item.system || !item.baseAmount) return [];
      return preferredDisplayUnits[item.system]
        .filter(unit => unitSystems[item.system][unit])
        .filter(unit => convertFromBaseUnit(item.baseAmount, unit, item.system) >= 0.2)
        .map(unit => ({ value: unit, label: unit }));
    }

    function getSplitAmountOptions(item, unit){
      if (!item.hasAdjustableQty || !item.system || !item.baseAmount || !unit) {
        return [{ value: "all", label: "Använd allt" }];
      }

      const totalInUnit = convertFromBaseUnit(item.baseAmount, unit, item.system);
      if (totalInUnit === null || totalInUnit <= 0) {
        return [{ value: "all", label: "Använd allt" }];
      }

      const options = [{ value: "all", label: `Använd allt (${item.label})` }];
      const maxWhole = Math.floor(totalInUnit);

      for (let amount = 1; amount <= maxWhole; amount++) {
        if (amount >= totalInUnit) break;
        options.push({
          value: String(amount),
          label: formatAmountWithUnit(amount, unit)
        });
      }

      return options;
    }

    function removeLeftoverFromBank(leftoverId){
      if (!leftoverId) return;
      state.ingredientBank = state.ingredientBank.filter(item => item.id !== leftoverId);
    }

    function upsertBankIngredient(item){
      const existingIndex = state.ingredientBank.findIndex(x => x.id === item.id);
      if (existingIndex >= 0) {
        state.ingredientBank[existingIndex] = item;
      } else {
        state.ingredientBank.unshift(item);
      }
    }

    function applyIngredientSplit(item){
      removeLeftoverFromBank(item.leftoverId);
      item.leftoverId = null;

      if (!item.hasAdjustableQty || !item.baseAmount || item.selectedSplitAmount === "all") {
        item.adjustedLabel = item.label;
        return;
      }

      const selectedUnit = item.selectedSplitUnit || item.unit;
      const selectedAmount = Number(item.selectedSplitAmount);

      if (!selectedUnit || !selectedAmount || selectedAmount <= 0) {
        item.adjustedLabel = item.label;
        item.selectedSplitAmount = "all";
        return;
      }

      const usedBase = convertToBaseUnit(selectedAmount, selectedUnit, item.system);
      if (!usedBase || usedBase <= 0 || usedBase >= item.baseAmount) {
        item.adjustedLabel = item.label;
        item.selectedSplitAmount = "all";
        return;
      }

      const leftBase = item.baseAmount - usedBase;
      item.adjustedLabel = `${formatAmountWithUnit(selectedAmount, selectedUnit)}${item.rest ? " " + item.rest : ""}`.trim();

      const leftoverId = `leftover-${item.builderId}`;
      const leftoverLabel = formatIngredientFromBase(leftBase, item.system, item.rest, item.unit);

      upsertBankIngredient(createIngredientItem(leftoverLabel, {
        id: leftoverId,
        source: "leftover"
      }));

      item.leftoverId = leftoverId;
    }

    function restoreBuilderIngredientToBank(item){
      removeLeftoverFromBank(item.leftoverId);
      const restoreItem = createIngredientItem(item.label, {
        id: item.originalBankId || "bank-ingredient-" + bankItemCounter++,
        source: item.source || "imported"
      });
      upsertBankIngredient(restoreItem);
    }

