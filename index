    function detectIconFromText(text){
      const lower = text.toLowerCase();
      if (/(häll i|tillsätt|lägg i)/i.test(lower)) return "🫗";
      if (/vispa/i.test(lower)) return "🥣";
      if (/(blanda|blandas|mixa ihop)/i.test(lower)) return "🥄";
      if (/(värma i gryta|gryta)/i.test(lower)) return "svg-varma";
      if (/(till temperatur|temperatur)/i.test(lower)) return "🌡️";
      if (/(slickepott|vända in|vända in med)/i.test(lower)) return "svg-vanda-in";
      if (/(bröda|bröa)/i.test(lower)) return "svg-broda";
      if (/(skära|hacka|strimla)/i.test(lower)) return "🔪";
      if (/riva/i.test(lower)) return "svg-riva";
      if (/(stek|fräs)/i.test(lower)) return "🍳";
      if (/fritera/i.test(lower)) return "🍤";
      if (/(koka|sjuda|kastrull)/i.test(lower)) return "♨️";
      if (/(baka|grädda|ugn)/i.test(lower)) return "🔥";
      if (/(servera|lägg upp)/i.test(lower)) return "🍽️";
      if (/(form)/i.test(lower)) return "🍱";
      if (/(vila|jäsa|stå)/i.test(lower)) return "⏱️";
      return "📝";
    }

    function parseRecipeText(rawText){
      const lines = cleanLines(rawText);
      if (!lines.length) return null;

      let detectedTitle = "";
      let ingredients = [];

      const firstLine = lines[0];
      const hasAnyHeading = lines.some(isLikelyHeading);

      if (!isLikelyHeading(firstLine) && !isLikelyIngredient(firstLine) && firstLine.length <= 120) {
        detectedTitle = firstLine;
      }

      if (hasAnyHeading) {
        let mode = "";
        lines.forEach((line, index) => {
          if (index === 0 && detectedTitle && line === detectedTitle) return;
          if (isIngredientHeading(line)) {
            mode = "ingredients";
            return;
          }
          if (mode === "ingredients" && isLikelyIngredient(line) && !shouldBlockIngredientLine(line)) {
            ingredients.push(line.replace(/^[-•*]\s*/, ""));
          }
        });
      } else {
        lines.forEach((line, index) => {
          if (index === 0 && detectedTitle && line === detectedTitle) return;
          if (isLikelyIngredient(line) && !shouldBlockIngredientLine(line)) {
            ingredients.push(line.replace(/^[-•*]\s*/, ""));
          }
        });
      }

      return {
        title: detectedTitle,
        ingredients: dedupeLines(ingredients.filter(Boolean)),
        instructions: []
      };
    }

    async function importFromUrl(){
      const rawUrl = recipeUrlInput.value.trim();
      if (!rawUrl) {
        setUrlStatus("Klistra in en receptlänk först.", "warn");
        return;
      }

      let parsedUrl;
      try {
        parsedUrl = new URL(rawUrl);
      } catch (error) {
        setUrlStatus("Länken verkar inte vara giltig.", "warn");
        return;
      }

      importUrlBtn.disabled = true;
      setUrlStatus("Försöker hämta ingredienser från länken ...", "");

      const targetUrl = parsedUrl.href;
      const proxyUrl = "https://r.jina.ai/http://" + targetUrl.replace(/^https?:\/\//i, "");

      try {
        const response = await fetch(proxyUrl);
        if (!response.ok) throw new Error("Kunde inte läsa sidan.");

        const fetchedRaw = await response.text();

        const markdownParsed = extractIngredientsFromMarkdownHeadings(fetchedRaw);
        if (markdownParsed) {
          const parts = [];
          if (markdownParsed.ingredients.length) {
            parts.push("Ingredienser");
            parts.push(...markdownParsed.ingredients);
          }

          importText.value = parts.join("\n");
          addImportedContentToBanks(markdownParsed);
          setUrlStatus("Importerade bara ingredienser via ## Ingredienser.", "ok");
          return;
        }

        const cleaned = extractUsefulTextFromFetchedPage(fetchedRaw);
        if (!cleaned) throw new Error("Ingen text kunde läsas från länken.");

        const strictParsed = strictExtractIngredientSections(cleaned);
        if (!strictParsed) {
          importText.value = cleaned;
          setUrlStatus("Ingrediensrubriken hittades inte. Texten ligger i importfältet.", "warn");
          return;
        }

        const strictTextParts = [];
        if (strictParsed.title) strictTextParts.push(strictParsed.title);
        if (strictParsed.ingredients.length) {
          strictTextParts.push("Ingredienser");
          strictTextParts.push(...strictParsed.ingredients);
        }

        importText.value = strictTextParts.join("\n");
        addImportedContentToBanks(strictParsed);
        setUrlStatus("Importerade bara ingredienser. Steg hämtades inte från länken.", "ok");
      } catch (error) {
        setUrlStatus("Det gick inte att importera från länken automatiskt. Prova att kopiera ingredienslistan och klistra in den i textfältet istället.", "warn");
      } finally {
        importUrlBtn.disabled = false;
      }
    }

