        unitSelect.value = unitOptions.some(opt => opt.value === item.selectedSplitUnit) ? item.selectedSplitUnit : (unitOptions[0]?.value || item.unit);

        function renderAmountOptions(){
          const options = getSplitAmountOptions(item, unitSelect.value);
          amountSelect.innerHTML = options.map(opt => `<option value="${escapeHtml(opt.value)}">${escapeHtml(opt.label)}</option>`).join("");

          if (options.some(opt => opt.value === String(item.selectedSplitAmount))) {
