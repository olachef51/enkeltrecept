<!-- start SEKTION 1: RECEPTAPP BYGGBANK MED URL-IMPORT -->
<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Receptförenklare</title>
  <style>
    :root{
      --bg:#f5f7fb;
      --panel:#ffffff;
      --line:#d9e0ec;
      --text:#1f2937;
      --muted:#6b7280;
      --accent:#2f6fed;
      --accent-soft:#eaf1ff;
      --soft:#f8fbff;
      --danger:#8b1e1e;
      --ok:#0f766e;
      --ok-soft:#ecfdf5;
      --warn-soft:#fff7ed;
      --shadow:0 10px 30px rgba(22,34,51,.08);
      --radius:16px;
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:Arial, Helvetica, sans-serif;
      background:var(--bg);
      color:var(--text);
    }

    .app{
      max-width:1400px;
      margin:0 auto;
      padding:12px;
    }

    .topbar{
      display:flex;
      flex-wrap:wrap;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      margin-bottom:10px;
    }

    .title-wrap h1{
      margin:0 0 2px 0;
      font-size:23px;
    }

    .title-wrap p{
      margin:0;
      font-size:12px;
      color:var(--muted);
    }

    .toolbar{
      display:flex;
      flex-wrap:wrap;
      gap:6px;
    }

    .preview-toolbar{
      display:flex;
      flex-wrap:wrap;
      gap:6px;
      justify-content:flex-end;
      margin-bottom:8px;
    }

    button{
      border:none;
      border-radius:10px;
      padding:9px 12px;
      font-size:13px;
      font-weight:700;
      cursor:pointer;
      background:#111827;
      color:#fff;
    }

    button.secondary{
      background:#fff;
      color:#111827;
      border:1px solid var(--line);
    }

    button.accent{
      background:var(--accent);
    }

    button.soft{
      background:#eef4ff;
      color:#1246b9;
      border:1px solid #cfe0ff;
    }

    button.warn{
      background:var(--danger);
      color:#fff;
    }

    button.ghost{
      background:#fff;
      color:#111827;
      border:1px solid var(--line);
      padding:4px 6px;
      font-size:10px;
      border-radius:8px;
    }

    button:disabled{
      opacity:.55;
      cursor:not-allowed;
    }

    input[type="text"], textarea, select, input[type="number"], input[type="url"]{
      width:100%;
      padding:10px 11px;
      border-radius:10px;
      border:1px solid var(--line);
      font-size:13px;
      background:#fff;
      font-family:Arial, Helvetica, sans-serif;
    }

    textarea{
      min-height:130px;
      resize:vertical;
      line-height:1.35;
    }

    .panel{
      background:var(--panel);
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      padding:10px;
    }

    .panel h2{
      margin:0 0 8px 0;
      font-size:17px;
    }

    .stack{
      display:flex;
      flex-direction:column;
      gap:10px;
    }

    .import-grid{
      display:grid;
      grid-template-columns:1fr auto;
      gap:8px;
      align-items:start;
    }

    .import-actions{
      display:flex;
      flex-direction:column;
      gap:6px;
      min-width:190px;
    }

    .url-row{
      display:grid;
      grid-template-columns:1fr auto;
      gap:8px;
      align-items:end;
      margin-bottom:8px;
    }

    .status-box{
      margin-top:8px;
      padding:8px 10px;
      border-radius:10px;
      font-size:12px;
      line-height:1.3;
      border:1px solid var(--line);
      background:#fff;
      color:var(--text);
    }

    .status-box.ok{
      background:var(--ok-soft);
      border-color:#a7f3d0;
      color:var(--ok);
    }

    .status-box.warn{
      background:var(--warn-soft);
      border-color:#fdba74;
      color:#9a3412;
    }

    .workspace{
      display:grid;
      grid-template-columns:1.08fr .92fr;
      gap:10px;
      align-items:start;
    }

    .workspace-left{
      display:flex;
      flex-direction:column;
      gap:10px;
    }

    .workspace-topbar,
    .bank-topbar,
    .saved-topbar{
      display:flex;
      flex-wrap:wrap;
      justify-content:space-between;
      align-items:center;
      gap:6px;
      margin-bottom:8px;
    }

    .bank-toolbar{
      display:flex;
      flex-wrap:wrap;
      gap:6px;
    }

    .drop-block h3,
    .bank-block h3,
    .step-preview-box h3,
    .special-box h3{
      margin:0 0 6px 0;
      font-size:13px;
      color:#374151;
    }

    .dropzone{
      min-height:52px;
      border:2px dashed #b7c5e5;
      border-radius:12px;
      background:#fbfcff;
      padding:8px;
      display:flex;
      flex-wrap:wrap;
      gap:6px;
      align-items:flex-start;
      transition:.15s ease;
    }

    .dropzone.active{
      background:#eef4ff;
      border-color:var(--accent);
    }

    .dropzone-empty{
      color:var(--muted);
      font-size:12px;
      line-height:1.15;
      padding:1px;
    }

    .bank-columns{
      display:grid;
      grid-template-columns:1fr;
      gap:10px;
    }

    .bank-list{
      display:flex;
      flex-wrap:wrap;
      gap:6px;
      min-height:34px;
      padding:1px 0;
    }

    .bank-card,
    .assigned-card{
      display:inline-flex;
      align-items:flex-start;
      gap:5px;
      background:#fff;
      border:1px solid var(--line);
      border-radius:11px;
      padding:5px 7px;
      max-width:100%;
    }

    .bank-card{
      cursor:grab;
      user-select:none;
    }

    .bank-card.ingredient-card{ background:#fdfdfd; }
    .bank-card.instruction-card{ background:#f8fbff; }

    .assigned-card{
      border-color:#cfe0ff;
      background:#fff;
      flex-direction:column;
      min-width:140px;
      max-width:180px;
      align-items:center;
      padding:5px 6px;
    }

    .assigned-main{
      width:100%;
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:4px;
      justify-content:center;
      text-align:center;
    }

    .assigned-extra{
      width:100%;
      display:flex;
      flex-direction:column;
      gap:4px;
      margin-top:3px;
      align-items:center;
    }

    .assigned-split-row{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:4px;
      width:100%;
    }

    .assigned-split-select{
      font-size:11px;
      padding:5px 6px;
    }

    .assigned-remainder{
      font-size:10px;
      color:#1246b9;
      background:#eef4ff;
      border:1px solid #cfe0ff;
      border-radius:8px;
      padding:5px 6px;
      line-height:1.15;
      text-align:center;
      width:100%;
    }

    .icon-chip{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:20px;
      height:20px;
      border-radius:999px;
      background:var(--accent-soft);
      font-size:11px;
      border:1px solid #cfe0ff;
      flex:0 0 20px;
      overflow:hidden;
    }

    .icon-chip svg{
      width:14px;
      height:14px;
      display:block;
      stroke:#1246b9;
      fill:none;
      stroke-width:1.8;
      stroke-linecap:round;
      stroke-linejoin:round;
    }

    .icon-chip svg .fill{
      fill:#1246b9;
      stroke:none;
    }

    .card-text{
      min-width:0;
      text-align:center;
      flex:1 1 auto;
      width:100%;
    }

    .card-text strong{
      display:block;
      font-size:11px;
      word-break:break-word;
      line-height:1.1;
    }

    .card-text span{
      display:block;
      color:var(--muted);
      font-size:9px;
      margin-top:1px;
      word-break:break-word;
      line-height:1.1;
    }

    .assigned-controls{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:4px;
      margin-left:0;
      flex:0 0 auto;
      width:100%;
    }

    .remove-assigned{
      background:#fff;
      color:var(--danger);
      border:1px solid #efc3c3;
      padding:4px 6px;
      font-size:9px;
      border-radius:8px;
      flex:0 0 auto;
    }

    .builder-actions{
      display:flex;
      flex-wrap:wrap;
      gap:6px;
      margin-top:8px;
    }

    .custom-instruction-box{
      margin-top:8px;
    }

    .custom-instruction-box label,
    .special-grid label{
      display:block;
      margin-bottom:4px;
      font-size:12px;
      font-weight:700;
      color:#374151;
    }

    .special-box{
      margin-top:8px;
      padding:8px;
      border:1px solid var(--line);
      border-radius:12px;
      background:var(--soft);
    }

    .special-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:8px;
    }

    .step-preview-box{
      margin-top:8px;
      padding:6px;
      border:1px solid var(--line);
      border-radius:12px;
      background:var(--soft);
    }

    .step-preview-card{
      background:#fff;
      border:1px solid var(--line);
      border-radius:10px;
      padding:5px 6px;
      display:grid;
      grid-template-columns:minmax(0,1fr) 16px auto;
      align-items:center;
      justify-content:center;
      gap:6px;
      width:100%;
      max-width:320px;
      margin:0 auto;
      text-align:center;
    }

    .step-preview-left{
      min-width:0;
      width:100%;
      display:flex;
      justify-content:center;
      align-items:center;
      text-align:center;
    }

    .step-preview-left ul{
      margin:0;
      padding-left:0;
      list-style-position:inside;
      display:inline-block;
      text-align:center;
    }

    .step-preview-left li{
      margin:1px 0;
      font-size:11px;
      line-height:1.1;
      text-align:center;
    }

    .step-preview-link{
      display:flex;
      align-items:center;
      justify-content:center;
      color:#4b6fcb;
      font-weight:700;
      font-size:13px;
      line-height:1;
      width:100%;
    }

    .step-preview-right{
      background:var(--accent-soft);
      border:1px solid #cfe0ff;
      border-radius:8px;
      padding:5px 8px;
      display:flex;
      flex-direction:column;
      gap:2px;
      justify-content:center;
      align-items:center;
      text-align:center;
      width:max-content;
      max-width:none;
      margin:0 auto;
      white-space:nowrap;
    }

    .instruction-line{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:4px;
      font-size:11px;
      font-weight:700;
      line-height:1.05;
      text-align:center;
      width:100%;
      white-space:nowrap;
      flex-wrap:nowrap;
    }

    .instruction-line span:last-child{
      white-space:nowrap;
    }

    .small-note{
      margin-top:4px;
      color:var(--muted);
      font-size:11px;
      line-height:1.2;
    }

    .status-chip{
      display:inline-flex;
      align-items:center;
      gap:5px;
      padding:6px 8px;
      border-radius:10px;
      background:#eef4ff;
      border:1px solid #cfe0ff;
      font-size:12px;
      font-weight:700;
      color:#1246b9;
    }

    .saved-steps{
      display:flex;
      flex-direction:column;
      gap:8px;
    }

    .saved-step-card{
      border:1px solid var(--line);
      border-radius:12px;
      background:#fff;
      padding:6px;
    }

    .saved-step-head{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:6px;
      margin-bottom:4px;
    }

    .saved-step-title{
      font-size:11px;
      font-weight:800;
      color:#374151;
    }

    .saved-step-actions{
      display:flex;
      flex-wrap:wrap;
      gap:4px;
    }

    .mini-btn{
      padding:5px 6px;
      border-radius:8px;
      font-size:10px;
      font-weight:700;
    }

    .mini-btn.secondary{
      background:#fff;
      color:#111827;
      border:1px solid var(--line);
    }

    .recipe-title-card{
      margin-bottom:8px;
      padding:6px 8px;
      border:1px solid var(--line);
      border-radius:12px;
      background:#fff;
    }

    .recipe-title-card h3{
      margin:0;
      font-size:18px;
      line-height:1.1;
      text-align:center;
    }

    .recipe-preview{
      display:flex;
      flex-direction:column;
      gap:5px;
      align-items:center;
    }

    .preview-step{
      background:#fff;
      border:1px solid var(--line);
      border-radius:10px;
      padding:5px 6px;
      display:grid;
      grid-template-columns:minmax(0,1fr) 16px auto;
      align-items:center;
      justify-content:center;
      gap:6px;
      width:100%;
      max-width:320px;
      margin:0 auto;
      text-align:center;
    }

    .preview-ingredients{
      display:flex;
      justify-content:center;
      align-items:center;
      text-align:center;
      width:100%;
    }

    .preview-ingredients ul{
      margin:0;
      padding-left:0;
      list-style-position:inside;
      display:inline-block;
      text-align:center;
    }

    .preview-ingredients li{
      margin:1px 0;
      font-size:11px;
      line-height:1.1;
      text-align:center;
    }

    .preview-arrow{
      display:flex;
      align-items:center;
      justify-content:center;
      color:#4b6fcb;
      font-size:13px;
      font-weight:700;
      line-height:1;
      width:100%;
    }

    .preview-instruction{
      background:var(--accent-soft);
      border:1px solid #cfe0ff;
      border-radius:8px;
      padding:5px 8px;
      display:flex;
      flex-direction:column;
      gap:2px;
      justify-content:center;
      align-items:center;
      text-align:center;
      width:max-content;
      max-width:none;
      margin:0 auto;
      white-space:nowrap;
      min-width:120px;
    }

    .preview-empty{
      padding:10px;
      border:1px dashed var(--line);
      border-radius:12px;
      color:var(--muted);
      background:#fff;
      font-size:12px;
    }

    @media (max-width:1150px){
      .workspace{
        grid-template-columns:1fr;
      }

      .special-grid,
      .url-row,
      .assigned-split-row{
        grid-template-columns:1fr;
      }

      .step-preview-card,
      .preview-step{
        max-width:320px;
      }

      .import-grid{
        grid-template-columns:1fr;
      }

      .import-actions{
        min-width:auto;
      }
    }

    @media print{
      @page{
        margin:10mm;
      }

      html, body{
        background:#fff !important;
      }

      body *{
        visibility:hidden !important;
      }

      .preview-panel,
      .preview-panel *{
        visibility:visible !important;
      }

      .preview-panel{
        position:absolute;
        left:0;
        top:0;
        width:100%;
        background:#fff;
        border:none !important;
        box-shadow:none !important;
        padding:0 !important;
        margin:0 !important;
      }

      .preview-panel h2,
      .preview-toolbar{
        display:none !important;
      }

      .recipe-title-card{
        border:none !important;
        box-shadow:none !important;
        padding:0 0 6px 0 !important;
        margin:0 0 6px 0 !important;
      }

      .recipe-title-card h3{
        font-size:16px !important;
      }

      .recipe-preview{
        gap:4px !important;
        align-items:center !important;
      }

      .preview-step{
        break-inside:avoid;
        border:1px solid #bbb !important;
        border-radius:10px !important;
        padding:5px 6px !important;
        margin:0 0 4px 0 !important;
        width:100% !important;
        max-width:280px !important;
        gap:5px !important;
        grid-template-columns:minmax(0,1fr) 12px 110px !important;
      }

      .preview-ingredients ul{
        padding-left:0 !important;
        list-style-position:inside !important;
      }

      .preview-ingredients li{
        font-size:10px !important;
        margin:1px 0 !important;
        line-height:1.05 !important;
      }

      .preview-arrow{
        display:flex !important;
        font-size:11px !important;
      }

      .preview-instruction{
        padding:4px 6px !important;
        gap:2px !important;
        border-radius:8px !important;
        width:110px !important;
        min-width:110px !important;
        max-width:110px !important;
        white-space:nowrap !important;
        overflow:hidden !important;
      }

      .instruction-line{
        font-size:10px !important;
        gap:3px !important;
        line-height:1.05 !important;
        width:100% !important;
        justify-content:center !important;
      }

      .icon-chip{
        width:16px !important;
        height:16px !important;
        min-width:16px !important;
        font-size:9px !important;
      }

      .icon-chip svg{
        width:11px !important;
        height:11px !important;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <div class="title-wrap">
        <h1>Receptförenklare</h1>
        <p>Importera till byggbanken, bygg ett steg i taget och spara det till receptet.</p>
      </div>
      <div class="toolbar">
        <button id="printBtn" class="secondary">🖨️ Printa ut</button>
        <button id="saveRecipeBtn" class="accent">💾 Spara recept</button>
        <button id="resetRecipeBtn" class="warn">🗑️ Nytt recept</button>
      </div>
    </div>

    <div class="stack">
      <div class="panel">
        <h2>Rubrik</h2>
        <input id="recipeTitleInput" type="text" placeholder="Skriv receptets rubrik här, t.ex. Pannkakor" />
      </div>

      <div class="panel import-panel">
        <h2>Importera recept</h2>

        <div class="url-row">
          <div>
            <input id="recipeUrlInput" type="url" placeholder="Klistra in receptlänk här, t.ex. https://www.ica.se/recept/..." />
          </div>
          <button id="importUrlBtn" class="accent">Importera från länk</button>
        </div>

        <div id="urlImportStatus" class="status-box">Ingen länk importerad ännu.</div>

        <div class="import-grid" style="margin-top:8px;">
          <div>
            <textarea id="importText" placeholder="Klistra in recept här. Appen lägger importerade ingredienser i byggbanken till höger."></textarea>
            <div class="small-note">
              Tips: klistra in hela receptet. Dra sedan över rätt ingredienser till arbetsytan och välj instruktioner från byggbanken.
            </div>
          </div>
          <div class="import-actions">
            <button id="parseRecipeBtn" class="accent">Tolka till byggbank</button>
            <button id="importIngredientsBtn" class="soft">Bara ingredienser</button>
            <button id="clearImportBtn" class="secondary">Rensa importfält</button>
          </div>
        </div>
      </div>

      <div class="workspace">
        <div class="workspace-left">
          <div class="panel builder-panel">
            <div class="workspace-topbar">
              <h2>Bygg aktuellt steg här</h2>
              <div class="status-chip">Arbetsyta för nästa steg</div>
            </div>

            <div class="drop-block">
              <h3>Ingrediensgrupp</h3>
              <div id="builderIngredientZone" class="dropzone"></div>
            </div>

            <div class="drop-block" style="margin-top:8px;">
              <h3>Instruktion med bildstöd</h3>
              <div id="builderInstructionZone" class="dropzone"></div>
            </div>

            <div class="custom-instruction-box">
              <label for="builderCustomInstruction">Kort egen stegtext</label>
              <input id="builderCustomInstruction" type="text" placeholder="Skriv en mycket kort förklarande text här">
            </div>

            <div id="builderSpecialHost"></div>

            <div id="builderPreviewHost" class="step-preview-box"></div>

            <div class="builder-actions">
              <button id="saveStepBtn" class="accent">Spara till recept</button>
              <button id="clearBuilderBtn" class="secondary">Rensa arbetsyta</button>
            </div>
          </div>

          <div class="panel saved-panel">
            <div class="saved-topbar">
              <h2>Sparade steg i receptet</h2>
            </div>
            <div id="savedSteps" class="saved-steps"></div>
          </div>
        </div>

        <div class="panel bank-panel">
          <div class="bank-topbar">
            <h2>Byggbank</h2>
            <div class="bank-toolbar">
              <button id="clearBankBtn" class="warn">Rensa byggbank</button>
            </div>
          </div>

          <div class="bank-columns">
            <div class="bank-block">
              <h3>Importerade ingredienser</h3>
              <div id="ingredientBank" class="bank-list"></div>
              <div class="small-note">Dra ingredienser härifrån till arbetsytan.</div>
            </div>

            <div class="bank-block">
              <h3>Instruktioner med bildstöd</h3>
              <div id="instructionBank" class="bank-list"></div>
              <div class="small-note">Välj instruktioner härifrån. URL-importen fyller inte på steg längre.</div>
            </div>
          </div>
        </div>
      </div>

      <div class="panel preview-panel">
        <div class="preview-toolbar">
          <button id="printBtnBottom" class="secondary">🖨️ Printa ut</button>
          <button id="saveRecipeBtnBottom" class="accent">💾 Spara recept</button>
          <button id="resetRecipeBtnBottom" class="warn">🗑️ Nytt recept</button>
        </div>
        <h2>Elevversion</h2>
        <div id="recipeTitlePreview"></div>
        <div id="recipePreview" class="recipe-preview"></div>
      </div>
    </div>
  </div>

  <script>
    const customSvgIcons = {
