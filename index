            const temp = step.ovenTemp ? `${step.ovenTemp}°` : "";
            const mins = step.ovenMinutes ? `${step.ovenMinutes} min` : "";
            if (temp || mins) {
              text = `Ugn${temp || mins ? " – " : ""}${temp}${temp && mins ? " i " : ""}${mins}`;
