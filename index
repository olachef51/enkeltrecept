            builderId: "builder-ingredient-" + builderIngredientCounter++,
            leftoverId: null
          }));
          state.builder.instructions = step.instructions.map(item => ({ ...item }));
          state.builder.customInstruction = step.customInstruction || "";
          state.builder.restMinutes = Number(step.restMinutes) || 0;
          state.builder.ovenTemp = step.ovenTemp || "";
          state.builder.ovenMinutes = step.ovenMinutes || "";
          state.builder.targetTemp = step.targetTemp || "";

          builderCustomInstructionEl.value = state.builder.customInstruction;

          state.recipeSteps.splice(index, 1);
          renderAll();
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
        actions.appendChild(editBtn);

        head.appendChild(title);
        head.appendChild(actions);

        const previewBox = document.createElement("div");
        previewBox.className = "step-preview-box";
        previewBox.innerHTML = `<h3>Så här ser steget ut i receptet</h3>`;

        const previewCard = document.createElement("div");
        previewCard.className = "step-preview-card";

        const left = document.createElement("div");
        left.className = "step-preview-left";
        const ul = document.createElement("ul");

        if (step.ingredients.length) {
          step.ingredients.forEach(item => {
            const li = document.createElement("li");
            li.textContent = getIngredientDisplayLabel(item);
            ul.appendChild(li);
          });
        } else {
          const li = document.createElement("li");
          li.textContent = "Inga ingredienser";
          ul.appendChild(li);
        }
        left.appendChild(ul);

        const link = document.createElement("div");
        link.className = "step-preview-link";
        link.textContent = step.ingredients.length >= 2 ? "}" : "→";

        const right = document.createElement("div");
        right.className = "step-preview-right";
        appendInstructionLines(right, step);

        previewCard.appendChild(left);
        previewCard.appendChild(link);
        previewCard.appendChild(right);
        previewBox.appendChild(previewCard);

        card.appendChild(head);
        card.appendChild(previewBox);
        savedStepsEl.appendChild(card);
      });
    }

    function renderBank(){
      renderBankList(ingredientBankEl, state.ingredientBank);
      renderBankList(instructionBankEl, state.instructionBank);
    }

    function renderPreview(){
      recipePreviewEl.innerHTML = "";
      recipeTitlePreview.innerHTML = "";

      const title = (state.title || recipeTitleInput.value).trim();
      if (title) {
        recipeTitlePreview.innerHTML = `
          <div class="recipe-title-card">
            <h3>${escapeHtml(title)}</h3>
          </div>
        `;
      }

      if (!state.recipeSteps.length) {
        recipePreviewEl.innerHTML = `<div class="preview-empty">Spara steg till receptet för att visa elevversionen här.</div>`;
        return;
      }

      state.recipeSteps.forEach((step) => {
        const stepEl = document.createElement("div");
        stepEl.className = "preview-step";

        const ingredientsEl = document.createElement("div");
        ingredientsEl.className = "preview-ingredients";
        const ul = document.createElement("ul");

        if (step.ingredients.length) {
          step.ingredients.forEach(item => {
            const li = document.createElement("li");
            li.textContent = getIngredientDisplayLabel(item);
            ul.appendChild(li);
          });
        } else {
          const li = document.createElement("li");
          li.textContent = "Inga ingredienser";
          ul.appendChild(li);
        }
        ingredientsEl.appendChild(ul);

        const arrowEl = document.createElement("div");
        arrowEl.className = "preview-arrow";
        arrowEl.textContent = step.ingredients.length >= 2 ? "}" : "→";

        const instructionBox = document.createElement("div");
        instructionBox.className = "preview-instruction";
        appendInstructionLines(instructionBox, step);

        stepEl.appendChild(ingredientsEl);
        stepEl.appendChild(arrowEl);
        stepEl.appendChild(instructionBox);

        recipePreviewEl.appendChild(stepEl);
      });
    }

    function renderAll(){
      renderBank();
      renderBuilder();
      renderSavedSteps();
      renderPreview();
    }

    function clearBank(){
      resetIngredientBankWithAlwaysAvailable();
      state.instructionBank = [...defaultInstructionLibrary.map(item => ({ ...item }))];
      renderAll();
    }

    function resetWholeRecipe(){
      state.title = "";
      recipeTitleInput.value = "";
      importText.value = "";
      recipeUrlInput.value = "";
      state.recipeSteps = [];
      setUrlStatus("Ingen länk importerad ännu.", "");
      clearBuilder();
      resetIngredientBankWithAlwaysAvailable();
      state.instructionBank = [...defaultInstructionLibrary.map(item => ({ ...item }))];
      renderAll();
    }

    function saveRecipeToFile(){
      const payload = {
        title: (state.title || recipeTitleInput.value || "").trim(),
        ingredientBank: state.ingredientBank,
        instructionBank: state.instructionBank,
        recipeSteps: state.recipeSteps,
        exportedAt: new Date().toISOString()
      };

      const safeTitle = (payload.title || "recept").toLowerCase()
        .replace(/[^\wåäö-]+/gi, "-")
        .replace(/-+/g, "-")
        .replace(/^-|-$/g, "");

      const blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = `${safeTitle || "recept"}.json`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    }

    function escapeHtml(text){
      return String(text)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    recipeTitleInput.addEventListener("input", () => {
      state.title = recipeTitleInput.value;
      renderPreview();
    });

    builderCustomInstructionEl.addEventListener("input", () => {
      state.builder.customInstruction = builderCustomInstructionEl.value;
      renderBuilderPreview();
    });

    parseRecipeBtn.addEventListener("click", () => {
      const parsed = parseRecipeText(importText.value);
      if (!parsed) return;
      addImportedContentToBanks(parsed);
    });

    importIngredientsBtn.addEventListener("click", () => {
      addIngredientsOnlyToBank(importText.value);
    });

    clearImportBtn.addEventListener("click", () => {
      importText.value = "";
    });

    clearBankBtn.addEventListener("click", () => {
      clearBank();
    });

    clearBuilderBtn.addEventListener("click", () => {
      clearBuilder();
      renderBank();
    });

    saveStepBtn.addEventListener("click", () => {
      saveBuilderToRecipe();
    });

    printBtn.addEventListener("click", () => {
      window.print();
    });

    printBtnBottom.addEventListener("click", () => {
      window.print();
    });

    saveRecipeBtn.addEventListener("click", () => {
      saveRecipeToFile();
    });

    saveRecipeBtnBottom.addEventListener("click", () => {
      saveRecipeToFile();
    });

    resetRecipeBtn.addEventListener("click", () => {
      resetWholeRecipe();
    });

    resetRecipeBtnBottom.addEventListener("click", () => {
      resetWholeRecipe();
    });

    importUrlBtn.addEventListener("click", () => {
      importFromUrl();
    });

    resetIngredientBankWithAlwaysAvailable();
    renderAll();
  </script>
</body>
</html>
