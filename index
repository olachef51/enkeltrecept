    function setupDropzone(zoneEl, acceptedType, onDropItem){
      zoneEl.ondragover = (e) => {
        e.preventDefault();
        zoneEl.classList.add("active");
      };

      zoneEl.ondragleave = () => {
        zoneEl.classList.remove("active");
      };

      zoneEl.ondrop = (e) => {
        e.preventDefault();
        e.stopPropagation();
        zoneEl.classList.remove("active");

        let payload = null;
        try {
          payload = JSON.parse(e.dataTransfer.getData("application/json"));
        } catch (error) {
          payload = null;
        }

        if (!payload || payload.itemType !== acceptedType) return;

        const item = findBankItemById(payload.bankId);
        if (!item) return;

        onDropItem(item);
      };
    }

