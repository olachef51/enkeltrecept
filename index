    function addImportedContentToBanks(parsed){
      if (!parsed) return;

      if (parsed.title) {
        state.title = parsed.title;
        recipeTitleInput.value = parsed.title;
      }

      const uniqueIngredients = dedupeAgainstBank(parsed.ingredients.filter(Boolean));
      uniqueIngredients.forEach(line => {
        state.ingredientBank.push(createIngredientItem(line));
      });

      if (parsed.instructions && parsed.instructions.length) {
        parsed.instructions.filter(Boolean).forEach(line => {
          state.instructionBank.push(makeInstructionBankItem(line));
        });
      }

      renderAll();
    }

    function addIngredientsOnlyToBank(rawText){
      const lines = cleanLines(rawText)
        .map(line => line.replace(/^[-•*]\s*/, ""))
        .filter(line => !isLikelyHeading(line))
        .filter(line => !shouldBlockIngredientLine(line))
        .filter(line => isLikelyIngredient(line));

      const uniqueLines = dedupeAgainstBank(dedupeLines(lines));
      uniqueLines.forEach(line => state.ingredientBank.push(createIngredientItem(line)));
      renderAll();
    }

